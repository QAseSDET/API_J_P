    {
      "name": "Board API",
      "item": [
        {
          "name": "Get Specific Board Data",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log(\"starting\");\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const targetName = pm.collectionVariables.get(\"targetBoardName\");",
                  "let found = false;",
                  "",
                  "for (const item of response) {",
                  "    if (item.name === targetName) {",
                  "        pm.collectionVariables.set(\"boardid\", item.id);",
                  "        console.log(targetName + \" found! boardid stored:\", item.id);",
                  "        found = true;",
                  "        break;",
                  "    }",
                  "}",
                  "",
                  "if (!found) {",
                  "    console.log(targetName + \" not found\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{url}}/1/members/me/boards?fields=name,url&key={{key}}&token={{token}}",
              "host": [
                "{{url}}"
              ],
              "path": [
                "1",
                "members",
                "me",
                "boards"
              ],
              "query": [
                {
                  "key": "fields",
                  "value": "name,url"
                },
                {
                  "key": "key",
                  "value": "{{key}}"
                },
                {
                  "key": "token",
                  "value": "{{token}}"
                }
              ]
            }
          },
          "response": []
        },
